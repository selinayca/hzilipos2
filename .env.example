# ─────────────────────────────────────────────
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# App
NODE_ENV=development
APP_PORT=3001

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=hizlipos
DB_PASS=hizlipos_secret
DB_NAME=hizlipos_dev
DB_SYNC=false          # true only in local dev, NEVER in production
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES=7d

# Domain config
APP_DOMAIN=example.com       # used for CORS and tenant subdomain parsing
BACKOFFICE_URL=http://app.example.com
API_URL=http://api.example.com

# POS Web (Next.js public vars)
NEXT_PUBLIC_API_URL=http://api.example.com
NEXT_PUBLIC_APP_DOMAIN=example.com
